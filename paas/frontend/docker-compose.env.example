# =============================================================================
# Docker Compose runtime env
# =============================================================================
# This file is the single config Compose loads for paas-frontend (see paas/docker-compose.yml).
# Jenkins sync does NOT read bind-mounted paas/frontend/.env — put JENKINS_* only here (or in the
# compose `environment:` overrides).
#
# --- Swarm stack `my-stack` (docker service ls) — published ports on the manager ---------------
# Replace SWARM_LAN_IP with the address your browser uses (VM / manager NIC, not 172.18.0.1).
#
#   Jenkins        SWARM_LAN_IP:30090     my-stack_jenkins
#   PostgreSQL     SWARM_LAN_IP:5432     my-stack_postgres
#   Argo CD        SWARM_LAN_IP:30081    my-stack_argocd
#   Grafana        SWARM_LAN_IP:30082    my-stack_grafana
#   Prometheus     SWARM_LAN_IP:30083    my-stack_prometheus
#   Alertmanager   SWARM_LAN_IP:30084    my-stack_alertmanager
#   Nexus          SWARM_LAN_IP:30085    my-stack_nexus
#   SonarQube      SWARM_LAN_IP:30086    my-stack_sonarqube
#   Pushgateway    SWARM_LAN_IP:30088    my-stack_pushgateway
#   Kibana         SWARM_LAN_IP:5601     my-stack_kibana
#   Elasticsearch  SWARM_LAN_IP:9200     my-stack_elasticsearch
#   Portainer      SWARM_LAN_IP:9443     my-stack_portainer
#   Trivy server   SWARM_LAN_IP:4954     my-stack_trivy
#   OWASP ZAP      SWARM_LAN_IP:8090     my-stack_zap   (8080 in-container → 8090 host)
#
# Optional on same host (not always part of my-stack): Vault UI :8200; `paas-postgres` :5433 (this compose file).
# Example LAN IP of the Docker manager (replace every 192.168.56.129 below if yours differs).

NODE_ENV=development

NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_DEFAULT_NAMESPACE=devsecops

NEXT_PUBLIC_GRAFANA_URL=http://192.168.56.129:30082
NEXT_PUBLIC_PROMETHEUS_URL=http://192.168.56.129:30083
NEXT_PUBLIC_ALERTMANAGER_URL=http://192.168.56.129:30084
NEXT_PUBLIC_PUSHGATEWAY_URL=http://192.168.56.129:30088
NEXT_PUBLIC_INGRESS_NGINX_URL=http://192.168.56.129:31504
NEXT_PUBLIC_KUBERNETES_DASHBOARD_URL=https://192.168.56.129:30089
NEXT_PUBLIC_NEXUS_URL=http://192.168.56.129:30085
NEXT_PUBLIC_OWASP_ZAP_URL=http://192.168.56.129:8090
NEXT_PUBLIC_VAULT_UI_URL=http://192.168.56.129:8200

NEXUS_URL=http://192.168.56.129:30085

# PaaS UI (paas-frontend container publishes 3000:3000).
APP_BASE_URL=http://192.168.56.129:3000
APPS_PUBLIC_URL_SCHEME=http
APPS_PUBLIC_BASE_DOMAIN=apps.local
APPS_PUBLIC_URL_TEMPLATE=
APPS_REACHABILITY_TIMEOUT_MS=8000

# When using `paas/docker-compose.yml` as-is, the compose file sets DATABASE_URL to the bundled
# `postgres` service and overrides this file — you can omit DATABASE_URL here or comment it out.
# Swarm Postgres on the host (my-stack_postgres :5432): use your DB user/pass and host.docker.internal.
# Standalone paas-postgres on host :5433 (common when port 5432 is already Swarm):
DATABASE_URL=postgresql://postgres:root@host.docker.internal:5433/paas?options=-c%20lc_messages%3DC

JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=2h
AUTH_ALLOW_UNVERIFIED_LOGIN=false

# =============================================================================
# Jenkins
# =============================================================================
# Each JENKINS_* key must appear ONCE. Duplicate keys in this file: the LAST value wins
# (easy to end up with a stale JENKINS_API_TOKEN / wrong URL).
#
# Use the SAME host/port as "Jenkins URL" in Manage Jenkins → System (what you type in the browser).
# Do NOT use the Docker bridge gateway (e.g. http://172.18.0.1:30090) if Jenkins is configured as
# http://YOUR_VM:30090 — requests then get Host: 172.18.0.1 and Jenkins often returns HTTP 403.
# From inside the container, the VM/LAN IP is usually routable (test with wget/curl below).
JENKINS_URL=http://192.168.56.129:30090
JENKINS_BASE_URL=http://192.168.56.129:30090
JENKINS_USERNAME=your-jenkins-user
JENKINS_API_TOKEN=your-jenkins-api-token
JENKINS_BUILD_JOB_NAME=paas-deploy
JENKINS_DEPLOY_JOB_NAME=paas-deploy
JENKINS_AGENT_LABEL=built-in
JENKINS_SYNC_INLINE_JOB_BEFORE_TRIGGER=true

# Optional: Jenkins stage « 5. Construction » (npm ci) — set if the agent has no direct access to registry.npmjs.org
# BUILD_PACKAGE_PROXY_URL=http://proxy.example:8080
# BUILD_NPM_REGISTRY=https://registry.npmjs.org/

# =============================================================================
# Harbor / Registry
# =============================================================================
HARBOR_BASE_URL=http://192.168.56.129:30092
HARBOR_USERNAME=admin
HARBOR_PASSWORD=your-harbor-admin-password
HARBOR_PROJECT=paas
HARBOR_REGISTRY=192.168.56.129:30092

HELM_OCI_PROJECT=paas
HELM_OCI_INSECURE=false
HELM_OCI_PLAIN_HTTP=false

# =============================================================================
# ArgoCD / GitOps
# =============================================================================
ARGOCD_BASE_URL=https://192.168.56.129:30081
ARGOCD_AUTH_TOKEN=your-argocd-token
ARGOCD_TLS_SKIP_VERIFY=true
ARGOCD_APP_PREFIX=paas

GITOPS_REPO_URL=https://github.com/your-org/your-gitops-repo
GITOPS_DEFAULT_BRANCH=main
GITOPS_REPO_TOKEN=ghp_your_github_personal_access_token

# =============================================================================
# DockerHub
# =============================================================================
DOCKERHUB_USERNAME=your-dockerhub-username
DOCKERHUB_TOKEN=dckr_pat_your_docker_pat
DOCKERHUB_NAMESPACE=your-dockerhub-username

# =============================================================================
# Sonar / Security
# =============================================================================
SONAR_BASE_URL=http://192.168.56.129:30086
SONAR_TOKEN=your-sonar-token

# Dependency-Track / OPA: set only if you publish these ports from the swarm or another proxy.
DEPENDENCY_TRACK_BASE_URL=http://192.168.56.129:31260
DEPENDENCY_TRACK_API_KEY=your-dependency-track-api-key

TRIVY_BASE_URL=http://192.168.56.129:4954/
TRIVY_AUTH_TOKEN=your-trivy-token

PROMETHEUS_BASE_URL=http://192.168.56.129:30083

OPA_EVAL_URL=http://192.168.56.129:31780/v1/data

# =============================================================================
# Cosign
# =============================================================================
COSIGN_ENFORCE_SIGNED=true
OPA_ENFORCE_SIGNED=true

COSIGN_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_WITH_YOUR_BASE64_PUBLIC_KEY_ONE_LINE\n-----END PUBLIC KEY-----"

# =============================================================================
# Kubernetes
# =============================================================================
# Swarm-only hosts: set false unless you also run Kubernetes and mount a kubeconfig into the app.
KUBERNETES_ENABLED=false
KUBE_CONFIG_PATH=/home/your-user/.kube/config
KUBE_TLS_SKIP_VERIFY=true
INTEGRATIONS_TLS_SKIP_VERIFY=true

# =============================================================================
# Mail
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-app-password
MAIL_FROM=you@example.com

# =============================================================================
# Misc
# =============================================================================
GITHUB_WEBHOOK_SECRET=your-webhook-hmac-secret-min-32-chars-recommended
GITHUB_WEBHOOK_BUILD_MODE=prompt

DEVSECOPS_ALLOW_SIMULATION=false
PAAS_STRICT_INTEGRATIONS=false
