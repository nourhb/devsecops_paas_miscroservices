# Copy to paas/frontend/docker-compose.env and fill tokens.
#
# === Lab reference: k3s (example 3-node, control-plane 192.168.56.129) ===
# Re-verify after helm upgrades: kubectl get svc -A
# Namespaces in use: argocd, harbor, monitoring, security, sonarqube, cicd, cert-manager,
#   gatekeeper-system, kyverno, kube-system (traefik), vault, paas, databases, demo, demo-app
#
# NodePorts (target -> published on each node IP):
#   Argo CD server:     https 30374, http 31752   (argocd/argocd-server)
#   Harbor portal/API:  30002                     (harbor/harbor -> 80)
#   Jenkins:            30090                     (cicd/jenkins-service -> 8080)
#   Prometheus (legacy svc): 30083                (monitoring/prometheus-service -> 9090)
#   Prometheus (stack):      30536                (monitoring/kube-prometheus-stack-prometheus)
#   Grafana (legacy):        30082                (monitoring/grafana-service -> 3000)
#   Grafana (kube-prom stack): 32383              (monitoring/kube-prometheus-stack-grafana -> 80)
#   Alertmanager:            30772 (9093)         (monitoring/kube-prometheus-stack-alertmanager)
#   Traefik HTTP:            30659                (kube-system/traefik LoadBalancer also 192.168.56.128-130)
#   Traefik HTTPS:           31398
#   Trivy:                   30954                (security/trivy-service; not target 4954)
#   SonarQube:               30900                (sonarqube/sonarqube-service)
#   PaaS UI (in-cluster):    30100                (paas/frontend-service)
# Pushgateway (monitoring/pushgateway-prometheus-pushgateway) is often ClusterIP-only — expose a
#   NodePort or port-forward before setting NEXT_PUBLIC_PUSHGATEWAY_URL.
# Vault UI (vault/vault) is ClusterIP:8200 — same (NodePort, port-forward, or Ingress).

NODE_ENV=development

NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_DEFAULT_NAMESPACE=devsecops

# Pick one Grafana NodePort (stack vs legacy); 32383 matches kube-prometheus-stack-grafana.
NEXT_PUBLIC_GRAFANA_URL=http://192.168.56.129:32383
NEXT_PUBLIC_PROMETHEUS_URL=http://192.168.56.129:30083
NEXT_PUBLIC_ALERTMANAGER_URL=http://192.168.56.129:30772
# NEXT_PUBLIC_PUSHGATEWAY_URL=http://192.168.56.129:<nodeport>   # expose Pushgateway first (see header)
# Optional deep links (Platform hub catalog).
# NEXT_PUBLIC_KUBE_STATE_METRICS_URL=
# Traefik ingress uses hosts grafana.local / prometheus.local — add /etc/hosts -> 192.168.56.129 if you use that path instead of NodePorts.
# NEXT_PUBLIC_KIBANA_URL=
# NEXT_PUBLIC_ELASTICSEARCH_URL=
# NEXT_PUBLIC_PORTAINER_URL=
# NEXT_PUBLIC_DEPENDENCY_CHECK_URL=
# NEXT_PUBLIC_OWASP_DEPENDENCY_CHECK_URL=
# NEXT_PUBLIC_TERRAFORM_CLOUD_URL=
# NEXT_PUBLIC_HAPROXY_STATS_URL=
# NEXT_PUBLIC_EDGE_IOT_URL=

# Traefik is the ingress controller (not ingress-nginx). HTTP NodePort 30659 on lab node.
NEXT_PUBLIC_INGRESS_NGINX_URL=http://192.168.56.129:30659
# INGRESS_NGINX_PROBE_URL=http://host.docker.internal:30659

NEXT_PUBLIC_KUBERNETES_DASHBOARD_URL=
# NEXT_PUBLIC_NEXUS_URL=http://192.168.56.129:30085   # if you deploy Nexus with a NodePort
NEXT_PUBLIC_OWASP_ZAP_URL=http://192.168.56.129:8090
# NEXT_PUBLIC_VAULT_UI_URL=http://192.168.56.129:<vault-nodeport>   # expose vault:8200 first

# NEXUS_URL=http://192.168.56.129:30085

APP_BASE_URL=http://192.168.56.129:3000
APPS_PUBLIC_URL_SCHEME=http
APPS_PUBLIC_BASE_DOMAIN=apps.local
APPS_PUBLIC_URL_TEMPLATE=
APPS_REACHABILITY_TIMEOUT_MS=8000

DATABASE_URL=postgresql://postgres:root@host.docker.internal:5433/paas?options=-c%20lc_messages%3DC

JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=2h
AUTH_ALLOW_UNVERIFIED_LOGIN=false

NOTIFY_PIPELINE_FAILURE_EMAILS=true

KEYCLOAK_ENABLED=false
KEYCLOAK_ISSUER=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ADMIN_ROLE=

JENKINS_URL=http://192.168.56.129:30090
JENKINS_BASE_URL=http://192.168.56.129:30090
JENKINS_USERNAME=your-jenkins-user
JENKINS_API_TOKEN=your-jenkins-api-token
JENKINS_BUILD_JOB_NAME=paas-deploy
JENKINS_DEPLOY_JOB_NAME=paas-deploy
JENKINS_AGENT_LABEL=built-in
JENKINS_SYNC_INLINE_JOB_BEFORE_TRIGGER=true
JENKINS_PAAS_FAST_PIPELINE=false
PAAS_MONOREPO_ROOT=/monorepo

HARBOR_BASE_URL=http://192.168.56.129:30002
HARBOR_USERNAME=admin
HARBOR_PASSWORD=your-harbor-admin-password
HARBOR_PROJECT=paas
HARBOR_REGISTRY=192.168.56.129:30002

HELM_OCI_PROJECT=paas
HELM_OCI_INSECURE=false
HELM_OCI_PLAIN_HTTP=false

ARGOCD_BASE_URL=https://192.168.56.129:30374
ARGOCD_AUTH_TOKEN=your-argocd-token
ARGOCD_TLS_SKIP_VERIFY=true
ARGOCD_APP_PREFIX=paas

GITOPS_REPO_URL=https://github.com/your-org/your-gitops-repo
GITOPS_DEFAULT_BRANCH=main
GITOPS_REPO_TOKEN=ghp_your_github_personal_access_token

DOCKERHUB_USERNAME=your-dockerhub-username
DOCKERHUB_TOKEN=dckr_pat_your_docker_pat
DOCKERHUB_NAMESPACE=your-dockerhub-username

SONAR_BASE_URL=http://192.168.56.129:30900
SONAR_TOKEN=your-sonar-token

DEPENDENCY_TRACK_BASE_URL=http://192.168.56.129:31260
DEPENDENCY_TRACK_API_KEY=your-dependency-track-api-key

TRIVY_BASE_URL=http://192.168.56.129:30954/
TRIVY_AUTH_TOKEN=your-trivy-token

PROMETHEUS_BASE_URL=http://192.168.56.129:30083

# Deploy OPA in-cluster or pick a reachable NodePort; placeholder was 31780 in older examples.
OPA_EVAL_URL=http://192.168.56.129:31780/v1/data

COSIGN_ENFORCE_SIGNED=true
OPA_ENFORCE_SIGNED=true

COSIGN_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_WITH_YOUR_BASE64_PUBLIC_KEY_ONE_LINE\n-----END PUBLIC KEY-----"

KUBERNETES_ENABLED=false
KUBE_CONFIG_PATH=/home/nextjs/.kube/config
KUBE_TLS_SKIP_VERIFY=true
INTEGRATIONS_TLS_SKIP_VERIFY=true
# INTEGRATIONS_PROBE_HOST_REMAP=192.168.56.129=host.docker.internal

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-app-password
MAIL_FROM=you@example.com

GITHUB_WEBHOOK_SECRET=your-webhook-hmac-secret-min-32-chars-recommended
GITHUB_WEBHOOK_BUILD_MODE=prompt

DEVSECOPS_ALLOW_SIMULATION=false
PAAS_STRICT_INTEGRATIONS=false
