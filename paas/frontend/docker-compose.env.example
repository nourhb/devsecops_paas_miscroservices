# =============================================================================
# Docker Compose runtime env ONLY (copy to docker-compose.env — do not commit)
# =============================================================================
# Or: keep one frontend/.env and run  node scripts/flatten-env-for-compose.mjs  (writes this file).
# Docker Compose reads this file with a strict line-based parser: every value must
# be a SINGLE line. Multi-line PEM blocks in `frontend/.env` WILL break `docker compose up`.
#
#   cp frontend/docker-compose.env.example frontend/docker-compose.env
#   nano frontend/docker-compose.env
#
# `docker-compose.yml` sets DATABASE_URL for the frontend container (Postgres service);
# your DATABASE_URL line here is overridden when using bundled postgres.
#
# One-line PEM (Cosign): use \n between lines, in double quotes, e.g.
# COSIGN_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nBASE64...\n-----END PUBLIC KEY-----"
# Or leave COSIGN_* empty in the container and mount keys another way.
# =============================================================================

NODE_ENV=production

NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_DEFAULT_NAMESPACE=devsecops
NEXT_PUBLIC_GRAFANA_URL=http://127.0.0.1:30082
NEXT_PUBLIC_PROMETHEUS_URL=http://127.0.0.1:30083
NEXT_PUBLIC_ALERTMANAGER_URL=http://127.0.0.1:30084
NEXT_PUBLIC_PUSHGATEWAY_URL=http://127.0.0.1:30088
NEXT_PUBLIC_INGRESS_NGINX_URL=
NEXT_PUBLIC_KUBERNETES_DASHBOARD_URL=
NEXT_PUBLIC_NEXUS_URL=http://127.0.0.1:30085
NEXT_PUBLIC_VAULT_UI_URL=

APP_BASE_URL=http://localhost:3000
APPS_PUBLIC_URL_SCHEME=http
APPS_PUBLIC_BASE_DOMAIN=apps.local
APPS_PUBLIC_URL_TEMPLATE=
APPS_REACHABILITY_TIMEOUT_MS=8000

DATABASE_URL=postgresql://postgres:root@postgres:5432/paas?options=-c%20lc_messages%3DC

JWT_SECRET=change-this-to-at-least-32-characters-long-secret-key
JWT_EXPIRES_IN=2h
AUTH_ALLOW_UNVERIFIED_LOGIN=false

JENKINS_URL=http://127.0.0.1:8080
JENKINS_BASE_URL=http://127.0.0.1:8080
JENKINS_USERNAME=admin
JENKINS_API_TOKEN=your-jenkins-api-token
JENKINS_BUILD_JOB_NAME=paas-deploy
JENKINS_DEPLOY_JOB_NAME=paas-deploy
JENKINS_SYNC_INLINE_JOB_BEFORE_TRIGGER=false

HARBOR_BASE_URL=
HARBOR_USERNAME=
HARBOR_PASSWORD=
HARBOR_PROJECT=paas
HARBOR_REGISTRY=
HELM_OCI_PROJECT=paas
HELM_OCI_INSECURE=false
HELM_OCI_PLAIN_HTTP=false

ARGOCD_BASE_URL=https://argocd.example.com
ARGOCD_AUTH_TOKEN=
ARGOCD_TLS_SKIP_VERIFY=true
ARGOCD_APP_PREFIX=paas

SONAR_BASE_URL=
SONAR_TOKEN=

DEPENDENCY_TRACK_BASE_URL=
DEPENDENCY_TRACK_API_KEY=

PROMETHEUS_BASE_URL=http://127.0.0.1:9090
TRIVY_BASE_URL=
TRIVY_AUTH_TOKEN=

DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=
DOCKERHUB_NAMESPACE=

GITOPS_REPO_URL=
GITOPS_DEFAULT_BRANCH=main
GITOPS_REPO_TOKEN=

COSIGN_ENFORCE_SIGNED=true
OPA_ENFORCE_SIGNED=true
POLICY_ENGINE=kyverno
KYVERNO_POLICIES_ENABLED=true

COSIGN_PUBLIC_KEY=
COSIGN_PRIVATE_KEY=

ARTIFACTORY_URL=
ARTIFACTORY_REPOSITORY=libs-release-local
ARTIFACTORY_USERNAME=
ARTIFACTORY_PASSWORD=
ARTIFACTORY_ACCESS_TOKEN=
ARTIFACTORY_CREDENTIALS_ID=
COSIGN_CREDENTIALS_ID=
NVD_API_KEY=

KUBERNETES_ENABLED=false
KUBE_CONFIG_PATH=
KUBE_TLS_SKIP_VERIFY=false
INTEGRATIONS_TLS_SKIP_VERIFY=false

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

GITHUB_WEBHOOK_SECRET=
DEVSECOPS_ALLOW_SIMULATION=false
PAAS_STRICT_INTEGRATIONS=false

OPA_EVAL_URL=
