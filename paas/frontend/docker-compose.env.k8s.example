# Copy to paas/frontend/docker-compose.env on the lab VM (NOT committed — contains secrets).
# PaaS runs in Kubernetes namespace paas, UI: http://192.168.56.129:30100
# Do NOT use host.docker.internal — pods cannot resolve it.

NODE_ENV=production
BUILD_BACKEND=jenkins
DEVSECOPS_ALLOW_SIMULATION=false
PAAS_STRICT_INTEGRATIONS=false

APP_BASE_URL=http://192.168.56.129:30100
APPS_PUBLIC_URL_SCHEME=http
APPS_PUBLIC_BASE_DOMAIN=apps.local
APPS_PUBLIC_URL_TEMPLATE=
APPS_PUBLIC_LAB_NODE_IP=192.168.56.129
APPS_PUBLIC_INGRESS_HTTP_PORT=30659

DATABASE_URL=postgresql://postgres:root@postgres.paas.svc.cluster.local:5432/paas?options=-c%20lc_messages%3DC

JWT_SECRET=change-me-long-random-at-least-32-chars
JWT_EXPIRES_IN=2h
AUTH_ALLOW_UNVERIFIED_LOGIN=false

INTEGRATIONS_PROBE_HOST_REMAP=
INTEGRATIONS_TLS_SKIP_VERIFY=true
PLATFORM_INTEGRATION_PROBE_TIMEOUT_MS=25000

JENKINS_URL=http://192.168.56.129:30090
JENKINS_BASE_URL=http://192.168.56.129:30090
JENKINS_PROBE_URL=http://192.168.56.129:30090
JENKINS_USERNAME=your-jenkins-user
JENKINS_API_TOKEN=your-jenkins-api-token
JENKINS_BUILD_JOB_NAME=paas-deploy
JENKINS_DEPLOY_JOB_NAME=paas-deploy
JENKINS_AGENT_LABEL=built-in
JENKINS_SYNC_INLINE_JOB_BEFORE_TRIGGER=true
JENKINS_PAAS_FAST_PIPELINE=false
JENKINS_NPM_SNAPSHOT_NODE_MODULES=false
PAAS_MONOREPO_ROOT=/app/paas-bundled

HARBOR_BASE_URL=http://192.168.56.129:30002
HARBOR_REGISTRY=192.168.56.129:30002
# Jenkins image push: Harbor first. Leave DOCKERHUB_NAMESPACE empty when using Harbor (avoids nourhb/app → Docker Hub).
DEPLOY_IMAGE_NAME_TEMPLATE=192.168.56.129:30002/paas/{{projectName}}
COSIGN_ALLOW_INSECURE_REGISTRY=true
HARBOR_PROBE_URL=http://192.168.56.129:30002
HARBOR_USERNAME=admin
HARBOR_PASSWORD=your-harbor-password
HARBOR_PROJECT=paas
HARBOR_REGISTRY=192.168.56.129:30002
HELM_OCI_INSECURE=true
HELM_OCI_PLAIN_HTTP=true

SONAR_BASE_URL=http://192.168.56.129:30900
SONAR_PROBE_URL=http://192.168.56.129:30900
SONAR_TOKEN=your-sonar-token

TRIVY_BASE_URL=http://192.168.56.129:30954/
TRIVY_PROBE_URL=http://192.168.56.129:30954/
TRIVY_AUTH_TOKEN=your-trivy-token

NEXT_PUBLIC_GRAFANA_URL=http://192.168.56.129:32383
GRAFANA_PROBE_URL=http://192.168.56.129:32383
NEXT_PUBLIC_PROMETHEUS_URL=http://192.168.56.129:30536
PROMETHEUS_PROBE_URL=http://192.168.56.129:30536

ARGOCD_BASE_URL=https://192.168.56.129:30374
ARGOCD_AUTH_TOKEN=your-argocd-token
ARGOCD_TLS_SKIP_VERIFY=true
ARGOCD_APP_PREFIX=paas
ARGOCD_AUTO_CREATE_APPLICATION=true
ARGOCD_DEST_SERVER=https://kubernetes.default.svc
ARGOCD_APP_PROJECT=default

GITOPS_REPO_URL=https://github.com/your-org/gitops
GITOPS_DEFAULT_BRANCH=main
GITOPS_REPO_TOKEN=your-github-pat-with-repo-write

KUBERNETES_ENABLED=true
KUBE_CONFIG_PATH=
KUBE_TLS_SKIP_VERIFY=true
