generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DEVELOPER
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  fullName     String
  passwordHash String
  role         Role      @default(DEVELOPER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  projects     Project[]
}

model Project {
  id                     String   @id @default(uuid())
  projectName            String   @unique
  gitRepositoryUrl       String
  branch                 String
  language               String
  autoGenerateDockerfile Boolean  @default(false)
  autoGenerateHelmChart  Boolean  @default(false)
  namespace              String
  imageTag               String?
  buildStatus            String   @default("NOT_STARTED")
  lastDeploymentStatus   String   @default("NOT_DEPLOYED")
  podStatus              String   @default("UNKNOWN")
  buildLogs              String?
  deploymentLogs         String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  createdById            String
  createdBy              User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
}
