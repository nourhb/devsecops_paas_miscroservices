generator client {
  provider      = "prisma-client-js"
  // Windows/mac dev (native) + Alpine musl in Docker (openssl variant differs build vs run).
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(uuid())
  email                   String                   @unique
  fullName                String
  passwordHash            String
  role                    Role                     @default(DEVELOPER)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  emailVerifiedAt         DateTime?
  deployments             Deployment[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  projects                Project[]
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Project {
  id                     String           @id @default(uuid())
  projectName            String
  gitRepositoryUrl       String
  branch                 String
  language               String
  autoGenerateDockerfile Boolean          @default(false)
  autoGenerateHelmChart  Boolean          @default(false)
  namespace              String
  imageTag               String?
  buildStatus            String           @default("NOT_STARTED")
  lastDeploymentStatus   String           @default("NOT_DEPLOYED")
  podStatus              String           @default("UNKNOWN")
  buildLogs              String?
  deploymentLogs         String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  createdById            String
  url                    String?
  deletedAt              DateTime?
  gitCredentialsId       String?
  pendingGitHubPush      Json?
  containerImages        ContainerImage[]
  deployments            Deployment[]
  createdBy              User             @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([deletedAt])
}

model Deployment {
  id                      String                   @id @default(uuid())
  projectId               String
  status                  DeploymentJobStatus      @default(PENDING)
  jenkinsBuildNumber      Int?
  logs                    String?
  triggeredById           String?
  createdAt               DateTime                 @default(now())
  priorJenkinsBuildNumber Int?
  url                     String?
  failureReason           DeploymentFailureReason?
  failureMessage          String?
  project                 Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  triggeredBy             User?                    @relation(fields: [triggeredById], references: [id])

  @@index([projectId])
  @@index([createdAt])
}

model ContainerImage {
  id        String   @id @default(uuid())
  projectId String
  imageRef  String
  registry  String   @default("docker.io")
  action    String
  digest    String?
  logs      String?
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

enum Role {
  ADMIN
  DEVELOPER
}

enum DeploymentJobStatus {
  PENDING
  SUCCESS
  FAILED
  DEPLOYING
  DEPLOYED
}

enum DeploymentFailureReason {
  JENKINS
  GITOPS
  ARGOCD
  IMAGE_REF
  TRIGGER
  TIMEOUT
  UNKNOWN
}
