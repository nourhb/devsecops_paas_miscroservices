generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DEVELOPER
}

enum DeploymentJobStatus {
  PENDING
  SUCCESS
  DEPLOYING
  DEPLOYED
  FAILED
}

enum DeploymentFailureReason {
  JENKINS
  GITOPS
  ARGOCD
  IMAGE_REF
  TRIGGER
  TIMEOUT
  UNKNOWN
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  fullName     String
  passwordHash String
  role         Role         @default(DEVELOPER)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  projects     Project[]
  deployments  Deployment[]
}

model Project {
  id                     String   @id @default(uuid())
  projectName            String   @unique
  gitRepositoryUrl       String
  branch                 String
  language               String
  autoGenerateDockerfile Boolean  @default(false)
  autoGenerateHelmChart  Boolean  @default(false)
  namespace              String
  imageTag               String?
  buildStatus            String   @default("NOT_STARTED")
  lastDeploymentStatus   String   @default("NOT_DEPLOYED")
  podStatus              String   @default("UNKNOWN")
  buildLogs              String?
  deploymentLogs         String?
  // Public app URL after last successful deploy (e.g. https://my-app.apps.local).
  url                    String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  createdById            String
  createdBy              User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  containerImages        ContainerImage[]
  deployments            Deployment[]
}

// Jenkins deploy trigger record (one row per POST /api/deploy).
model Deployment {
  id                 String               @id @default(uuid())
  projectId          String
  project            Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status             DeploymentJobStatus  @default(PENDING)
  logs               String?              @db.Text
  failureReason      DeploymentFailureReason?
  failureMessage     String?              @db.Text
  // App URL for this deployment once DEPLOYED.
  url                String?
  jenkinsBuildNumber Int?
  // Last Jenkins build # before this deploy was triggered (find the new run).
  priorJenkinsBuildNumber Int?
  triggeredById      String?
  triggeredBy        User?                @relation(fields: [triggeredById], references: [id], onDelete: SetNull)
  createdAt          DateTime             @default(now())

  @@index([projectId])
  @@index([createdAt])
}

model ContainerImage {
  id         String   @id @default(uuid())
  projectId  String
  imageRef   String
  registry   String   @default("docker.io")
  action     String
  digest     String?
  logs       String?  @db.Text
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}
