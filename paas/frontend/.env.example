# =============================================================================
# DevSecOps PaaS - FINAL ENV (Cluster-based, NodePort)
# =============================================================================

NODE_ENV=development

# -----------------------------------------------------------------------------
# Frontend / Browser
# -----------------------------------------------------------------------------

NEXT_PUBLIC_API_BASE_URL=

NEXT_PUBLIC_DEFAULT_NAMESPACE=devsecops

NEXT_PUBLIC_GRAFANA_URL=http://192.168.56.129:31246
NEXT_PUBLIC_PROMETHEUS_URL=http://192.168.56.129:9090
NEXT_PUBLIC_ALERTMANAGER_URL=http://192.168.56.129:32432
NEXT_PUBLIC_PUSHGATEWAY_URL=http://192.168.56.129:31580

NEXT_PUBLIC_INGRESS_NGINX_URL=http://192.168.56.129:31504
NEXT_PUBLIC_KUBERNETES_DASHBOARD_URL=https://192.168.56.129:6443

NEXT_PUBLIC_NEXUS_URL=http://192.168.56.129:32000
NEXT_PUBLIC_VAULT_UI_URL=http://192.168.56.129:8200

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

APP_BASE_URL=http://192.168.56.129:3001

APPS_PUBLIC_URL_SCHEME=http
APPS_PUBLIC_BASE_DOMAIN=apps.local
APPS_PUBLIC_URL_TEMPLATE=http://{{subdomain}}.192.168.56.129.nip.io:31077

APPS_REACHABILITY_TIMEOUT_MS=8000

# -----------------------------------------------------------------------------
# Database (IMPORTANT ⚠️)
# -----------------------------------------------------------------------------

DATABASE_URL=postgresql://postgres:root@localhost:5432/paas

# 👉 إذا Postgres داخل Kubernetes (أفضل):
# DATABASE_URL=postgresql://postgres:root@postgres.default.svc.cluster.local:5432/paas

JWT_SECRET=CHANGE_ME_SUPER_SECRET_12345678901234567890
JWT_EXPIRES_IN=2h

AUTH_ALLOW_UNVERIFIED_LOGIN=false

# -----------------------------------------------------------------------------
# Jenkins
# -----------------------------------------------------------------------------

JENKINS_URL=http://192.168.56.129:31248
JENKINS_BASE_URL=http://192.168.56.129:31248
JENKINS_USERNAME=admin
JENKINS_API_TOKEN=REPLACE_ME

JENKINS_BUILD_JOB_NAME=paas-deploy
JENKINS_DEPLOY_JOB_NAME=paas-deploy
# Pod Template label (Manage Jenkins → Clouds → kubernetes). Required if builds hang: Jenkins doesn't have label jenkins-jenkins-agent
# JENKINS_AGENT_LABEL=jenkins-jenkins-agent
# Before first deploy: python paas/scripts/jenkins_create_paas_deploy_job.py (syncs Jenkinsfile.paas-deploy to Jenkins)

# -----------------------------------------------------------------------------
# Harbor (❗ NOT WORKING YET)
# -----------------------------------------------------------------------------

HARBOR_BASE_URL=http://192.168.56.129:30002
HARBOR_USERNAME=admin
HARBOR_PASSWORD=Harbor12345
HARBOR_PROJECT=paas

# ⚠️ إذا Harbor موش running → خليه هكا مؤقت

# -----------------------------------------------------------------------------
# ArgoCD
# -----------------------------------------------------------------------------

ARGOCD_BASE_URL=http://192.168.56.129:30609
ARGOCD_AUTH_TOKEN=REPLACE_ME
ARGOCD_TLS_SKIP_VERIFY=true
ARGOCD_APP_PREFIX=paas

# -----------------------------------------------------------------------------
# SonarQube
# -----------------------------------------------------------------------------

SONAR_BASE_URL=http://192.168.56.129:30415
SONAR_TOKEN=REPLACE_ME

# -----------------------------------------------------------------------------
# Dependency Track (❗ NOT INSTALLED)
# -----------------------------------------------------------------------------

DEPENDENCY_TRACK_BASE_URL=
DEPENDENCY_TRACK_API_KEY=

# -----------------------------------------------------------------------------
# Prometheus / Trivy
# -----------------------------------------------------------------------------

PROMETHEUS_BASE_URL=http://192.168.56.129:9090

TRIVY_BASE_URL=
TRIVY_AUTH_TOKEN=IYw0PMsWOZLZHbM7/WvVTLcUl8BzL4p+Hie4GmZJ37s=

# -----------------------------------------------------------------------------
# DockerHub
# -----------------------------------------------------------------------------

DOCKERHUB_USERNAME=nourhb
DOCKERHUB_TOKEN=REPLACE_ME
DOCKERHUB_NAMESPACE=nourhb

# -----------------------------------------------------------------------------
# GitOps
# -----------------------------------------------------------------------------

GITOPS_REPO_URL=https://github.com/nourhb/gitops
GITOPS_DEFAULT_BRANCH=main
GITOPS_REPO_TOKEN=REPLACE_ME

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

COSIGN_ENFORCE_SIGNED=true
OPA_ENFORCE_SIGNED=true

POLICY_ENGINE=kyverno
KYVERNO_POLICIES_ENABLED=true

# -----------------------------------------------------------------------------
# Kubernetes
# -----------------------------------------------------------------------------

KUBERNETES_ENABLED=true

# ❗ مهم: في Linux VM ما تستعملش Windows path
KUBE_CONFIG_PATH=/root/.kube/config

KUBE_TLS_SKIP_VERIFY=true
INTEGRATIONS_TLS_SKIP_VERIFY=true

# -----------------------------------------------------------------------------
# SMTP
# -----------------------------------------------------------------------------

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=nourhb58@gmail.com
SMTP_PASS=REPLACE_ME
MAIL_FROM=nourhb58@gmail.com

# -----------------------------------------------------------------------------
# Webhook
# -----------------------------------------------------------------------------

GITHUB_WEBHOOK_SECRET=REPLACE_ME

# -----------------------------------------------------------------------------
# Vault (مرحلة قادمة)
# -----------------------------------------------------------------------------

# لاحقاً:
# DATABASE_URL / TOKENS / SECRETS لازم تجي من Vault موش هنا

# -----------------------------------------------------------------------------

DEVSECOPS_ALLOW_SIMULATION=false