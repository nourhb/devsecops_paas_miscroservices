# =============================================================================
# DevSecOps PaaS — ملف البيئة الكامل / Complete environment reference
# انسخ إلى .env وعدّل القيم:  cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Next.js (عام / runtime)
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# المتصفح — NEXT_PUBLIC_* (تُعرَض للكلاينت)
# Browser / client-side (exposed to the browser)
# -----------------------------------------------------------------------------
# فارغ = نفس أصل التطبيق (مثلاً http://localhost:3000) للـ API routes
NEXT_PUBLIC_API_BASE_URL=

NEXT_PUBLIC_GRAFANA_URL=http://localhost:3001
NEXT_PUBLIC_PROMETHEUS_URL=http://localhost:9090
NEXT_PUBLIC_DEFAULT_NAMESPACE=devsecops

# -----------------------------------------------------------------------------
# قاعدة البيانات + JWT (إلزامي للتطبيق)
# Database + auth (required for app)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://paas:paas@localhost:5432/paas

# يجب 32 حرف على الأقل / min 32 characters (see env.ts)
JWT_SECRET=change-this-to-a-strong-secret-at-least-32-chars-long
JWT_EXPIRES_IN=2h

# -----------------------------------------------------------------------------
# Jenkins — CI/CD حقيقي عند تعبئة URL + user + token
# Real Jenkins when BASE_URL + USERNAME + API_TOKEN are set
# -----------------------------------------------------------------------------
JENKINS_BASE_URL=http://jenkins.local
JENKINS_USERNAME=admin
JENKINS_API_TOKEN=your-jenkins-api-token

# مسار مجلدات Jenkins (اختياري)، مثال: platform أو team-a/services
JENKINS_JOB_FOLDER=

# اسم باراميتر الفرع في buildWithParameters
JENKINS_BRANCH_PARAMETER=BRANCH

# true = استعمال /build بدل buildWithParameters (وظائف بلا باراميترات)
JENKINS_USE_SIMPLE_BUILD=false

# projectName = اسم الـ job كما في Jenkins | uuid = معرف المشروع من Prisma
JENKINS_JOB_NAME_SOURCE=projectName

# -----------------------------------------------------------------------------
# Harbor — سجل الحاويات
# Container registry
# -----------------------------------------------------------------------------
HARBOR_BASE_URL=https://harbor.local
HARBOR_USERNAME=admin
HARBOR_PASSWORD=password
HARBOR_PROJECT=paas

# -----------------------------------------------------------------------------
# Argo CD — النشر على الكلاستر
# -----------------------------------------------------------------------------
ARGOCD_BASE_URL=https://argocd.local
ARGOCD_AUTH_TOKEN=your-argocd-token
ARGOCD_APP_PREFIX=paas

# -----------------------------------------------------------------------------
# SonarQube — جودة الكود
# -----------------------------------------------------------------------------
SONAR_BASE_URL=https://sonarqube.local
SONAR_TOKEN=your-sonar-token

# -----------------------------------------------------------------------------
# Dependency-Track — الثغرات على التبعيات
# -----------------------------------------------------------------------------
DEPENDENCY_TRACK_BASE_URL=https://dependencytrack.local
DEPENDENCY_TRACK_API_KEY=your-dtrack-api-key

# -----------------------------------------------------------------------------
# Prometheus + Trivy — مراقبة وأمان الصور
# -----------------------------------------------------------------------------
PROMETHEUS_BASE_URL=http://localhost:9090
TRIVY_BASE_URL=http://trivy.local
TRIVY_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Cosign + OPA — سياسات التوقيع (true = فرض)
# Signing / policy enforcement
# -----------------------------------------------------------------------------
COSIGN_ENFORCE_SIGNED=true
OPA_ENFORCE_SIGNED=true

# -----------------------------------------------------------------------------
# GitOps — مستودع القيم (Helm) إن وُجد تكامل حقيقي
# -----------------------------------------------------------------------------
GITOPS_REPO_URL=https://github.com/org/gitops-repo
GITOPS_REPO_TOKEN=your-github-pat-or-token

# -----------------------------------------------------------------------------
# Docker Hub — API (JWT) للتحقق والوسوم
# -----------------------------------------------------------------------------
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=
DOCKERHUB_NAMESPACE=

# -----------------------------------------------------------------------------
# Kubernetes — عدّ البودات والعقد (يتطلب kubeconfig أو in-cluster)
# Pod/node counts (needs kubeconfig or in-cluster)
# -----------------------------------------------------------------------------
KUBERNETES_ENABLED=false
KUBE_CONFIG_PATH=

# =============================================================================
# ملخص: ما الذي يلزم كحد أدنى؟
# Minimum to run locally:
#   DATABASE_URL, JWT_SECRET (≥32 chars)
# الباقي اختياري — بدونها التطبيق يعمل بتصورات (simulated) للتكاملات
# Everything else is optional; integrations fall back to simulated behavior
# =============================================================================
