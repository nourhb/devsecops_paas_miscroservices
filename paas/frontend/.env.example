# =============================================================================
# DevSecOps PaaS - example env (copy to .env and fill in; never commit .env)
# =============================================================================
#
# For `docker compose up` from `paas/`, either:
#   - Maintain frontend/.env then run:  cd frontend && npm run env:compose
#     (writes docker-compose.env; do NOT edit docker-compose.env by hand — it will be overwritten.)
#   - Or copy docker-compose.env.example to docker-compose.env and edit only docker-compose.env (no generator).
# Compose cannot load multi-line PEM blocks; the generator flattens them for Docker.
#
# --- When the Next.js app runs INSIDE the paas-frontend container ---
# DATABASE_URL must not use localhost:5432 (localhost = the container). Use either:
#   postgresql://postgres:root@postgres:5432/paas?...   (default compose service name), or
#   postgresql://...@host.docker.internal:5432/paas?... (Postgres on the Docker host / Swarm published port), or
#   postgresql://...@host.docker.internal:5433/paas?... (standalone paas-postgres on host :5433).
# APP_BASE_URL must use the URL users open in the browser, e.g. http://MANAGER_IP:3000 (not :3001).
#
# --- Docker Swarm (stack "my-stack", published ports on manager) ---
# Replace SWARM_MANAGER_HOST. Map: ../jenkins/swarm-stack.env.example
#
# JENKINS_URL=http://SWARM_MANAGER_HOST:30090
# ARGOCD_BASE_URL=http://SWARM_MANAGER_HOST:30081
# SONAR_BASE_URL=http://SWARM_MANAGER_HOST:30086
# ...
#
# =============================================================================

NODE_ENV=development

# -----------------------------------------------------------------------------
# Frontend / Browser
# -----------------------------------------------------------------------------

NEXT_PUBLIC_API_BASE_URL=

NEXT_PUBLIC_DEFAULT_NAMESPACE=devsecops

NEXT_PUBLIC_GRAFANA_URL=http://127.0.0.1:30082
NEXT_PUBLIC_PROMETHEUS_URL=http://127.0.0.1:30083
NEXT_PUBLIC_ALERTMANAGER_URL=http://127.0.0.1:30084
NEXT_PUBLIC_PUSHGATEWAY_URL=http://127.0.0.1:30088

NEXT_PUBLIC_INGRESS_NGINX_URL=
NEXT_PUBLIC_KUBERNETES_DASHBOARD_URL=

NEXT_PUBLIC_NEXUS_URL=http://127.0.0.1:30085
NEXT_PUBLIC_VAULT_UI_URL=

# OWASP ZAP UI (optional; my-stack_zap often on host :8090)
NEXT_PUBLIC_OWASP_ZAP_URL=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

APP_BASE_URL=http://127.0.0.1:3000
# Plain HTTP (e.g. VM IP): use http:// in APP_BASE_URL so session cookies work, or set SESSION_COOKIE_SECURE=false.
# SESSION_COOKIE_SECURE=false

APPS_PUBLIC_URL_SCHEME=http
APPS_PUBLIC_BASE_DOMAIN=apps.local
APPS_PUBLIC_URL_TEMPLATE=

APPS_REACHABILITY_TIMEOUT_MS=8000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Local dev (next dev on host): localhost is OK. In Docker: use postgres or host.docker.internal (see header).
DATABASE_URL=postgresql://postgres:root@localhost:5432/paas

JWT_SECRET=change-this-to-at-least-32-characters-long-secret-key
JWT_EXPIRES_IN=2h

AUTH_ALLOW_UNVERIFIED_LOGIN=false

# Production `next start`: set false for Jenkins-only lab (skips Argo/GitOps mandatory checks)
# PAAS_STRICT_INTEGRATIONS=false

# -----------------------------------------------------------------------------
# Jenkins
# -----------------------------------------------------------------------------

JENKINS_URL=http://127.0.0.1:8080
JENKINS_BASE_URL=http://127.0.0.1:8080
JENKINS_USERNAME=admin
JENKINS_API_TOKEN=your-jenkins-api-token

JENKINS_BUILD_JOB_NAME=paas-deploy
JENKINS_DEPLOY_JOB_NAME=paas-deploy
JENKINS_SYNC_INLINE_JOB_BEFORE_TRIGGER=false
# PAAS_MONOREPO_ROOT=/absolute/path/to/repo-root
# JENKINS_AGENT_LABEL=jenkins-agent

# -----------------------------------------------------------------------------
# Harbor / registry
# -----------------------------------------------------------------------------

HARBOR_BASE_URL=
HARBOR_USERNAME=
HARBOR_PASSWORD=
HARBOR_PROJECT=paas
HARBOR_REGISTRY=
# Must be HARBOR_REGISTRY (double R). Not HARBOR_REGITRY.

HELM_OCI_PROJECT=paas
HELM_OCI_INSECURE=false
HELM_OCI_PLAIN_HTTP=false

# -----------------------------------------------------------------------------
# Argo CD
# -----------------------------------------------------------------------------

ARGOCD_BASE_URL=https://argocd.example.com
ARGOCD_AUTH_TOKEN=your-argocd-token
ARGOCD_TLS_SKIP_VERIFY=false
ARGOCD_APP_PREFIX=paas

# -----------------------------------------------------------------------------
# SonarQube
# -----------------------------------------------------------------------------

SONAR_BASE_URL=
SONAR_TOKEN=

# -----------------------------------------------------------------------------
# Dependency-Track
# -----------------------------------------------------------------------------

DEPENDENCY_TRACK_BASE_URL=
DEPENDENCY_TRACK_API_KEY=

# -----------------------------------------------------------------------------
# Prometheus / Trivy
# -----------------------------------------------------------------------------

PROMETHEUS_BASE_URL=http://127.0.0.1:9090

# Swarm stack my-stack usually publishes Trivy on host port 4954 (see docker service ls).
TRIVY_BASE_URL=http://127.0.0.1:4954/
TRIVY_AUTH_TOKEN=
# DAST: URL for OWASP ZAP baseline (Jenkins paas-deploy stage 10b); empty = skip
ZAP_TARGET_URL=

# -----------------------------------------------------------------------------
# Docker Hub (optional; crane / Jenkins)
# -----------------------------------------------------------------------------

DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=
DOCKERHUB_NAMESPACE=

# -----------------------------------------------------------------------------
# GitOps
# -----------------------------------------------------------------------------

GITOPS_REPO_URL=https://github.com/org/gitops-repo.git
GITOPS_DEFAULT_BRANCH=main
GITOPS_REPO_TOKEN=

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

COSIGN_ENFORCE_SIGNED=true
OPA_ENFORCE_SIGNED=true

POLICY_ENGINE=kyverno
KYVERNO_POLICIES_ENABLED=true

ARTIFACTORY_URL=
ARTIFACTORY_REPOSITORY=libs-release-local
ARTIFACTORY_USERNAME=
ARTIFACTORY_PASSWORD=
ARTIFACTORY_ACCESS_TOKEN=
ARTIFACTORY_CREDENTIALS_ID=
COSIGN_CREDENTIALS_ID=
NVD_API_KEY=

# -----------------------------------------------------------------------------
# Kubernetes (optional)
# -----------------------------------------------------------------------------

KUBERNETES_ENABLED=false

KUBE_CONFIG_PATH=
KUBE_TLS_SKIP_VERIFY=false
INTEGRATIONS_TLS_SKIP_VERIFY=false

# -----------------------------------------------------------------------------
# SMTP (optional)
# -----------------------------------------------------------------------------

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# -----------------------------------------------------------------------------
# Webhook
# -----------------------------------------------------------------------------

GITHUB_WEBHOOK_SECRET=
# Use a long random secret (HMAC for webhook verification). Do NOT paste a GitHub PAT here.
# GITHUB_WEBHOOK_BUILD_MODE=auto

DEVSECOPS_ALLOW_SIMULATION=false
