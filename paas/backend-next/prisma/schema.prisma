datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String
  createdAt DateTime @default(now())

  projects  Project[]
}

model Project {
  id           String   @id @default(cuid())
  name         String
  gitRepo      String
  registryRepo String
  createdAt    DateTime @default(now())

  ownerId  String
  owner    User    @relation(fields: [ownerId], references: [id])
  pipelines Pipeline[]
  deployments Deployment[]
}

model Pipeline {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id])
  buildNumber Int?
  status     String
  commitSha  String?
  createdAt  DateTime @default(now())

  scanResults ScanResult[]
}

model Deployment {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id])
  imageTag   String
  namespace  String
  status     String
  createdAt  DateTime @default(now())
}

model ScanResult {
  id         String   @id @default(cuid())
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id])
  scanner    String
  severity   String
  reportUrl  String?
}

