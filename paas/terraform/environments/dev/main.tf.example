# Example Terraform – Dev environment (skeleton)
# Adapt provider and module sources to your cloud (AWS / Azure / GCP).

terraform {
  required_version = ">= 1.0"
  required_providers {
    # aws = { source = "hashicorp/aws", version = "~> 5.0" }
    # google = { source = "hashicorp/google", version = "~> 5.0" }
    # azurerm = { source = "hashicorp/azurerm", version = "~> 3.0" }
  }
  backend "s3" {
    # bucket = "paas-terraform-state"
    # key    = "dev/terraform.tfstate"
    # region = "eu-west-1"
  }
}

