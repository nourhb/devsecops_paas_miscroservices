SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# Public frontend origin for CORS, for example your Vercel domain.
APP_CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app

# Jenkins integration
JENKINS_BASE_URL=https://jenkins.example.com
JENKINS_USERNAME=admin
JENKINS_API_TOKEN=replace-with-jenkins-api-token

# If your backend triggers a fixed Jenkins job name, set it here.
JENKINS_JOB_NAME=sample-build-job

# Optional JVM tuning
JAVA_OPTS=-Xms256m -Xmx512m
