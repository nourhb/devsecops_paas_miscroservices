# -----------------------------------------------------------------------------
# Docker Swarm stack "my-stack" — map published ports to PaaS / Jenkins
# -----------------------------------------------------------------------------
# From manager: docker service ls  (replace SWARM_HOST with hostname or IP, e.g. master)
#
# Service              Published (host -> container)   Env / usage
# -------------------  --------------------------------  -------------------------
# my-stack_jenkins     30090 -> 8080                   JENKINS_URL (PaaS .env)
# my-stack_argocd      30081 -> 8080                   ARGOCD_URL / ARGOCD_BASE_URL
# my-stack_grafana     30082 -> 3000                   NEXT_PUBLIC_GRAFANA_URL
# my-stack_prometheus  30083 -> 9090                   PROMETHEUS_BASE_URL, NEXT_PUBLIC_PROMETHEUS_URL
# my-stack_alertmanager 30084 -> 9093                  NEXT_PUBLIC_ALERTMANAGER_URL
# my-stack_nexus       30085 -> 8081                   NEXT_PUBLIC_NEXUS_URL ; optional raw repo URL for ops
# my-stack_sonarqube   30086 -> 9000                   SONAR_URL / SONAR_BASE_URL (+ SONAR_TOKEN)
# my-stack_pushgateway 30088 -> 9091                   NEXT_PUBLIC_PUSHGATEWAY_URL
# my-stack_trivy       4954  -> 4954                   TRIVY_BASE_URL (PaaS health/tooling; not a Jenkins param today)
# my-stack_zap         8090  -> 8080                   NEXT_PUBLIC_OWASP_ZAP_URL
# my-stack_postgres    5432  -> 5432                   DATABASE_URL (if this Postgres hosts the PaaS DB)
# my-stack_kibana      5601  -> 5601                   optional browser bookmark
# my-stack_elasticsearch 9200 -> 9200                  optional
# my-stack_portainer   9443  -> 9443                   optional (HTTPS UI)
#
# PaaS → Jenkins: triggers already pass SONAR_HOST_URL, SONAR_TOKEN, DEPENDENCY_TRACK_*,
# Docker Hub / Harbor-related params, ARTIFACTORY_* (URL, repo, user/token/password), HELM_OCI_*,
# NVD_API_KEY, COSIGN_CREDENTIALS_ID, ARTIFACTORY_CREDENTIALS_ID when set in paas/frontend/.env.
#
# Copy/paste: substitute your manager hostname/IP for SWARM_HOST (dotenv does not expand ${VAR}).
#
# JENKINS_URL=http://SWARM_HOST:30090
# ARGOCD_URL=http://SWARM_HOST:30081
# SONAR_URL=http://SWARM_HOST:30086
# SONAR_TOKEN=your-sonar-token
# PROMETHEUS_BASE_URL=http://SWARM_HOST:30083
# TRIVY_BASE_URL=http://SWARM_HOST:4954
# DEPENDENCY_TRACK_BASE_URL=
# DEPENDENCY_TRACK_API_KEY=
#
# Jenkins agent-only (Manage Jenkins → System → Global properties → Environment variables),
# if not supplied via job parameters / credentials:
# ARTIFACTORY_URL=
# ARTIFACTORY_REPOSITORY=
# ARTIFACTORY_USERNAME=
# ARTIFACTORY_PASSWORD=
# HARBOR_REGISTRY=
# HARBOR_USERNAME=
# HARBOR_PASSWORD=
# HELM_OCI_PROJECT=paas
# HELM_OCI_INSECURE=false
# HELM_OCI_PLAIN_HTTP=false
#
# Swarm: avoid Jenkins OOM (exit 137) — raise service memory limit and set JAVA_OPTS in the stack;
# see swarm-jenkins.example.yml in this folder.

