# =============================================================================
# PaaS — نسخ إلى .env وعدّل القيم (لا ترفع الأسرار إلى Git)
# Aliases: JENKINS_URL→JENKINS_BASE_URL, HARBOR_URL→HARBOR_BASE_URL (sauf docker.com),
#          GITOPS_REPO→GITOPS_REPO_URL, NEXT_PUBLIC_API_URL→base API (sans /api en double)
# =============================================================================

# --- Obligatoire ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/paas
JWT_SECRET=change-this-to-at-least-32-characters-long-secret

# --- Jenkins (aliases: JENKINS_URL, JENKINS_USER, JENKINS_TOKEN) ---
JENKINS_URL=http://192.168.56.129:8082
JENKINS_USER=admin
JENKINS_TOKEN=your-jenkins-api-token
# équivalent canonique / canonical:
# JENKINS_BASE_URL=http://192.168.56.129:8082
# JENKINS_USERNAME=admin
# JENKINS_API_TOKEN=...

JENKINS_JOB_FOLDER=
JENKINS_BRANCH_PARAMETER=BRANCH
JENKINS_USE_SIMPLE_BUILD=false
JENKINS_JOB_NAME_SOURCE=projectName
# Deploy job parameters (names must match the Jenkins job)
JENKINS_DEPLOY_GIT_URL_PARAMETER=GIT_URL
JENKINS_DEPLOY_BRANCH_PARAMETER=BRANCH
JENKINS_DEPLOY_IMAGE_NAME_PARAMETER=IMAGE_NAME
JENKINS_DEPLOY_PROJECT_ID_PARAMETER=PROJECT_ID
# Background polling after deploy (real Jenkins status)
JENKINS_DEPLOY_POLL_INTERVAL_MS=5000
JENKINS_DEPLOY_POLL_MAX_MS=3600000

# --- Registry ---
# Si HARBOR_URL pointe vers hub.docker.com → API Harbor désactivée; identifiants réutilisés pour DOCKERHUB_*
HARBOR_URL=https://hub.docker.com
HARBOR_USERNAME=your-dockerhub-user
HARBOR_PASSWORD=your-dockerhub-token-or-password
HARBOR_PROJECT=paas
# IMAGE_NAME for Jenkins: full ref or template with {{projectName}} / {{harborProject}}
DEPLOY_IMAGE_NAME_TEMPLATE=
DEPLOY_BRANCH_FALLBACK=main
# Optional: existing User id to record as deploy initiator instead of JWT user
DEPLOYMENT_TRIGGER_USER_ID=
# Vrai Harbor (API v2) / real Harbor registry:
# HARBOR_URL=https://harbor.example.com
# DOCKERHUB_NAMESPACE=   # optionnel si tu utilises DOCKERHUB_USERNAME séparé

DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=
DOCKERHUB_NAMESPACE=

# --- Argo CD (aliases: ARGOCD_URL, ARGOCD_TOKEN) ---
ARGOCD_URL=https://argocd.local
ARGOCD_TOKEN=
ARGOCD_APP_PREFIX=paas

# --- Deployed app URL (shown in UI after DEPLOYED) ---
# Default: https://{subdomain}.apps.local — subdomain is DNS-safe from project name.
APPS_PUBLIC_URL_SCHEME=https
APPS_PUBLIC_BASE_DOMAIN=apps.local
# Optional full template instead: https://{{subdomain}}.apps.local
APPS_PUBLIC_URL_TEMPLATE=
# Server-side HTTP probe timeout (ms) for GET /api/projects/:id/app-reachability
APPS_REACHABILITY_TIMEOUT_MS=8000

# --- Sonar (alias: SONAR_URL) ---
SONAR_URL=https://sonarqube.local
SONAR_TOKEN=

DEPENDENCY_TRACK_BASE_URL=
DEPENDENCY_TRACK_API_KEY=

PROMETHEUS_BASE_URL=http://localhost:9090
TRIVY_BASE_URL=
TRIVY_AUTH_TOKEN=

COSIGN_ENFORCE_SIGNED=true
OPA_ENFORCE_SIGNED=true
# Clé publique Cosign (PEM). Si tu mets par erreur une PUBLIC KEY dans COSIGN_PRIVATE_KEY, elle est détectée.
COSIGN_PUBLIC_KEY=
COSIGN_PRIVATE_KEY=

GITOPS_REPO=https://github.com/org/k8s-manifests.git
GITOPS_REPO_TOKEN=

# --- Kubernetes ---
KUBERNETES_ENABLED=false
KUBE_CONFIG_PATH=

# --- Next.js (frontend) ---
NEXT_PUBLIC_APP_NAME=DevOps Platform
# Base sans /api final (le client ajoute /api/...). Ex: http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_GRAFANA_URL=http://localhost:3001
NEXT_PUBLIC_PROMETHEUS_URL=http://localhost:9090
NEXT_PUBLIC_DEFAULT_NAMESPACE=devsecops

NODE_ENV=development
