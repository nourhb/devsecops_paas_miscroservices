
# -----------------------------------------------------------------------------
# Optional: Docker Swarm stack "my-stack" (docker service ls on manager)
# Replace SWARM_HOST with your manager hostname or IP (e.g. master).
# -----------------------------------------------------------------------------
# JENKINS_URL=http://SWARM_HOST:30090
# ARGOCD_URL=http://SWARM_HOST:30081
# SONAR_URL=http://SWARM_HOST:30086
# PROMETHEUS_BASE_URL=http://SWARM_HOST:30083
# TRIVY_BASE_URL=http://SWARM_HOST:4954
# DEPENDENCY_TRACK_BASE_URL=
# ARTIFACTORY_URL=http://SWARM_HOST:30085/repository/maven-releases/
# (Nexus layout differs from JFrog; tune path to your hosted repo.)
# NEXT_PUBLIC_GRAFANA_URL=http://SWARM_HOST:30082
# NEXT_PUBLIC_PROMETHEUS_URL=http://SWARM_HOST:30083
# NEXT_PUBLIC_ALERTMANAGER_URL=http://SWARM_HOST:30084
# NEXT_PUBLIC_PUSHGATEWAY_URL=http://SWARM_HOST:30088
# NEXT_PUBLIC_NEXUS_URL=http://SWARM_HOST:30085
# NEXT_PUBLIC_OWASP_ZAP_URL=http://SWARM_HOST:8090
# DATABASE_URL=postgresql://postgres:PASSWORD@SWARM_HOST:5432/paas
# See also: paas/jenkins/swarm-stack.env.example
# -----------------------------------------------------------------------------

DATABASE_URL=postgresql://postgres:root@localhost:5432/paas
JWT_SECRET=change-this-to-at-least-32-characters-long-secret

BUILD_BACKEND=jenkins
BUILD_TEMPLATE_VERSION=v1
BUILD_REGISTRY_MIRROR=mirror.gcr.io
BUILD_PACKAGE_PROXY_URL=
BUILD_ENFORCE_ARTIFACT_DIGEST=false

JENKINS_URL=http://192.168.56.129:8082
JENKINS_USER=admin
JENKINS_TOKEN=your-jenkins-api-token

JENKINS_JOB_FOLDER=
JENKINS_DEPLOY_JOB_NAME=
JENKINS_BRANCH_PARAMETER=BRANCH
JENKINS_USE_SIMPLE_BUILD=false
JENKINS_JOB_NAME_SOURCE=projectName
JENKINS_DEPLOY_GIT_URL_PARAMETER=GIT_URL
JENKINS_DEPLOY_BRANCH_PARAMETER=BRANCH
JENKINS_DEPLOY_IMAGE_NAME_PARAMETER=IMAGE_NAME
JENKINS_DEPLOY_PROJECT_ID_PARAMETER=PROJECT_ID
JENKINS_DEPLOY_POLL_INTERVAL_MS=5000
JENKINS_DEPLOY_POLL_MAX_MS=3600000
JENKINS_HTTP_TIMEOUT_MS=120000

HARBOR_URL=https://hub.docker.com
HARBOR_USERNAME=your-dockerhub-user
HARBOR_PASSWORD=your-dockerhub-token-or-password
HARBOR_PROJECT=paas
# Registry host:port (no scheme); overrides host derived from HARBOR_URL when set
HARBOR_REGISTRY=
# Projet Harbor pour charts Helm OCI (helm push … oci://HARBOR_REGISTRY/HELM_OCI_PROJECT) — aussi envoyé au job Jenkins si défini dans .env du frontend
HELM_OCI_PROJECT=paas
# true = helm registry login --insecure (certificat auto-signé / TLS atypique)
HELM_OCI_INSECURE=false
# true = helm push --plain-http (registre en HTTP uniquement)
HELM_OCI_PLAIN_HTTP=false
DEPLOY_IMAGE_NAME_TEMPLATE=
DEPLOY_BRANCH_FALLBACK=main
DEPLOYMENT_TRIGGER_USER_ID=

DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=
DOCKERHUB_NAMESPACE=

ARGOCD_URL=https://argocd.local
ARGOCD_TOKEN=
ARGOCD_APP_PREFIX=paas

APPS_PUBLIC_URL_SCHEME=https
APPS_PUBLIC_BASE_DOMAIN=apps.local
APPS_PUBLIC_URL_TEMPLATE=
APPS_REACHABILITY_TIMEOUT_MS=8000

SONAR_URL=https://sonarqube.local
SONAR_TOKEN=

ARTIFACTORY_URL=https://artifactory.local/artifactory
ARTIFACTORY_REPOSITORY=libs-release-local
ARTIFACTORY_USERNAME=
ARTIFACTORY_PASSWORD=
ARTIFACTORY_ACCESS_TOKEN=

# OWASP Dependency-Check NVD API (optional; forwarded to Jenkins)
NVD_API_KEY=

# Jenkins credential IDs (optional; not secrets — IDs in Jenkins credential store)
ARTIFACTORY_CREDENTIALS_ID=
COSIGN_CREDENTIALS_ID=

DEPENDENCY_TRACK_BASE_URL=
DEPENDENCY_TRACK_API_KEY=

PROMETHEUS_BASE_URL=http://localhost:9090
TRIVY_BASE_URL=
TRIVY_AUTH_TOKEN=

COSIGN_ENFORCE_SIGNED=true
OPA_ENFORCE_SIGNED=true
COSIGN_PUBLIC_KEY=
COSIGN_PRIVATE_KEY=
# Agent Jenkins : mot de passe de clé Cosign chiffrée ; Harbor HTTP / TLS auto-signé pour cosign sign
# COSIGN_PASSWORD=
# COSIGN_ALLOW_INSECURE_REGISTRY=false

GITOPS_REPO=https://github.com/org/k8s-manifests.git
GITOPS_REPO_TOKEN=

KUBERNETES_ENABLED=false
KUBE_CONFIG_PATH=

# Host path to kubeconfig for paas/docker-compose.yml frontend volume (bind-mount into container).
# Required for Cluster/Dashboard K8s views when the app runs in Docker. Use forward slashes on Windows.
# KUBECONFIG_HOST_PATH=C:/Users/you/.kube/config
TEKTON_API_VERSION=v1beta1
TEKTON_NAMESPACE=tekton-pipelines
TEKTON_SERVICE_ACCOUNT=paas-build-bot
TEKTON_NODE_PIPELINE_NAME=paas-node-build
TEKTON_DEFAULT_PIPELINE_NAME=paas-generic-build
TEKTON_POLL_INTERVAL_MS=5000
TEKTON_POLL_MAX_MS=3600000

NEXT_PUBLIC_APP_NAME=DevOps Platform
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_GRAFANA_URL=http://localhost:3001
NEXT_PUBLIC_PROMETHEUS_URL=http://localhost:9090
NEXT_PUBLIC_DEFAULT_NAMESPACE=devsecops

NODE_ENV=development
